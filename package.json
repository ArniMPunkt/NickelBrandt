{
  "name": "nickelbrandt",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@supabase/supabase-js": "^2.108.2",
    "expo": "~54.0.0",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.8",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-spotify-remote": "^0.3.10",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "android:aab": "powershell -ExecutionPolicy Bypass -File scripts/build-android-release.ps1 -Type aab",
    "android:apk": "powershell -ExecutionPolicy Bypass -File scripts/build-android-release.ps1 -Type apk",
    "release:ios": "rm -f NickelBrandt.ipa && expo prebuild --platform ios --clean && eas build --platform ios --local --profile production --output ./NickelBrandt.ipa && eas submit --platform ios --path ./NickelBrandt.ipa",
    "postinstall": "patch-package && node scripts/copy-spotify-xcframework.js"
  },
  "private": true
}
