# Spotify Developer Dashboard credentials.
# Copy this file to ".env" and fill in your own values.
#
# - CLIENT_ID: from https://developer.spotify.com/dashboard (your app)
# - REDIRECT_URI: must be registered EXACTLY in the dashboard under
#   "Edit Settings > Redirect URIs". Format <scheme>://<host>.
#   The scheme must match the app `scheme` in app.config.ts.
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=
EXPO_PUBLIC_SPOTIFY_REDIRECT_URI=nickelbrandt://spotify-login-callback
