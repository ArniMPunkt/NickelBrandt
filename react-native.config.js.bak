// React Native autolinking overrides.
//
// react-native-spotify-remote (v0.3.10, 2021) ships a bundled iOS SpotifySDK
// framework that is risky to build - especially the arm64 simulator slices on
// Apple Silicon Macs. Spotify PLAYBACK on iOS is a separate, later step, so we
// disable this module's iOS autolinking for now to keep the core iOS build green
// (navigation/UI, Online/Supabase, settings, etc.). Android is unaffected.
//
// Our app already tolerates the missing native module on iOS: spotify.ts loads
// the SDK lazily via a guarded getSDK(), so the Spotify tab simply reports
// "not ready" instead of crashing. To enable Spotify on iOS later, remove the
// `ios: null` override below and do the iOS-specific wiring (AppDelegate openURL
// + the access-token-based App Remote connect).
module.exports = {
  dependencies: {
    'react-native-spotify-remote': {
      platforms: {
        ios: null,
      },
    },
  },
};
