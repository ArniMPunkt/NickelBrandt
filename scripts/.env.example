# scripts/.env — secrets for the one-off song-pool import script ONLY.
#
# Copy this file to scripts/.env and fill in the values. scripts/.env is
# git-ignored. This is SEPARATE from the app .env (which holds only public
# EXPO_PUBLIC_* values). NEVER put the two secret values below into the app .env
# or anywhere that ends up in the app bundle.

# --- Spotify (Developer Dashboard) ---
# CLIENT_ID is the same value the app uses (not secret).
SPOTIFY_CLIENT_ID=
# CLIENT_SECRET is a REAL SECRET — fetch it from the Spotify Developer Dashboard
# (your app -> Settings -> "View client secret"). Server-to-server only.
SPOTIFY_CLIENT_SECRET=
#
# NOTE: scripts/.spotify-user-token.json is created AUTOMATICALLY on the first
# run of import-spotify-playlist.js (OAuth Authorization-Code/PKCE flow) — do NOT
# create it by hand, and never commit it (it is git-ignored).

# --- Supabase ---
# Same project URL the app uses (not secret).
SUPABASE_URL=
# SERVICE_ROLE_KEY is a REAL SECRET — Supabase Project Settings -> API ->
# "service_role". It BYPASSES Row Level Security, so the import can write to
# song_pools / pool_songs. Keep it private; never ship it in the app.
SUPABASE_SERVICE_ROLE_KEY=
